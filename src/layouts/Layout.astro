---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Enterprise Network Security Lab',
  description = 'Hands-on enterprise network security labs covering reconnaissance, ARP poisoning, ICMP, TCP, DNS, Heartbleed, firewalls, VPNs, and hardening.'
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020617" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
