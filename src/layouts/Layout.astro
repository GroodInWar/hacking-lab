---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Gustavo Sakamoto de Toledo | Cybersecurity Portfolio',
  description = 'Portfolio website for Gustavo Sakamoto de Toledo, focused on cybersecurity, secure software, networking, databases, and full-stack development.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020617" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>