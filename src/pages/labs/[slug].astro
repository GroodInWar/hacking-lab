---
/// <reference types="astro/astro-jsx" />
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

type MarkdownModule = {
  Content: any;
  frontmatter?: {
    title?: string;
    description?: string;
  };
};

export async function getStaticPaths() {
  const labModules = await import.meta.glob<MarkdownModule>('../../../docs/labs/*.md', {
    eager: true,
  });

  return Object.entries(labModules).map(([path, module]) => {
    const slug = path.split('/').pop()?.replace(/\.md$/, '');

    return {
      params: { slug },
      props: { module },
    };
  });
}

const { module } = Astro.props as { module: MarkdownModule };
const Content = module.Content;
const title = module.frontmatter?.title ?? 'Enterprise Network Security Lab';
const description = module.frontmatter?.description ?? 'Enterprise network security lab exercise.';
---

<Layout title={title} description={description}>
  <Navbar />
  <main class="docs-main">
    <article class="docs-content">
      <Content />
    </article>
    <Footer />
  </main>
</Layout>
