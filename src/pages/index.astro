---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

import { Image } from "astro:assets";
import networkTopology from "../assets/network-topology.png";
---

<Layout>
  <header id="top" class="hero-section">
    <Navbar />
    <div class="hero-content section-container">
      <p class="eyebrow">Network Security • Defense • Attacks</p>
      <h1>Enterprise Network Security Lab</h1>
      <p class="hero-summary">
        Welcome to the enterprise network security lab. This lab starts with a
        vulnerable enterprise-style network and guides you through a series of
        attacks and defenses. By completing the exercises, you will learn
        networking fundamentals, how common attacks work, and how to harden a
        segmented environment.
      </p>
      <Image src={networkTopology} alt="Network topology diagram" class="network-topology" />
    </div>
  </header>
  <main> 
    <Footer />
  </main>
</Layout>
